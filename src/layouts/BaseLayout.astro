---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Pupford - Better Training Treats",
  description = "Aesthetic hero redesign for Pupford freeze-dried training treats."
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#C8432F" />
    <title>{title}</title>

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://folio-fotos-proyectos.s3.us-east-2.amazonaws.com" crossorigin />
    <link rel="preconnect" href="https://pupford.com" crossorigin />
  </head>
  <body>
    <slot />
  </body>
</html>
