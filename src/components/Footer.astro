---
import "../styles/footer.css";

const LOGO_SRC = "https://pupford.com/cdn/shop/files/logo-light.png?v=1726716502&width=300";
const IOS_BADGE = "https://pupford.com/cdn/shop/files/ios-app-light.png?v=1726757239";
const ANDROID_BADGE = "https://pupford.com/cdn/shop/files/android-play-light.png?v=1726757238";

const footerLinks = [
  { label: "Shop Treats", href: "#" },
  { label: "Training", href: "#" },
  { label: "Our Story", href: "#" },
  { label: "Ambassador Program", href: "#" },
  { label: "Breeder Program", href: "#" },
  { label: "Find a Store", href: "#" },
  { label: "Become a Distributor", href: "#" },
  { label: "Brand Facts", href: "#" },
];

const legalBits = [
  { label: "Refund policy", href: "#" },
  { label: "Contact Information", href: "#" },
  { label: "Terms of service", href: "#" },
  { label: "Privacy policy", href: "#" },
  { label: "Shipping policy", href: "#" },
];
---

<footer class="site-footer">
  <div class="site-footer-inner">
    <div class="footer-ambassador-row">
      <a class="footer-ambassador" href="#">Join Pupford Ambassadors</a>
    </div>

    <div class="footer-main">
      <div class="footer-brand">
        <a href="#" aria-label="Pupford home">
          <img class="footer-logo" src={LOGO_SRC} alt="Pupford" width="220" height="56" loading="lazy" decoding="async" />
        </a>
        <p class="footer-download-label">Download App</p>
        <div class="footer-app-badges">
          <a href="#" aria-label="Download on the App Store">
            <img src={IOS_BADGE} alt="" width="160" height="48" loading="lazy" decoding="async" />
          </a>
          <a href="#" aria-label="Get it on Google Play">
            <img src={ANDROID_BADGE} alt="" width="168" height="48" loading="lazy" decoding="async" />
          </a>
        </div>
      </div>

      <nav class="footer-nav" aria-label="Footer">
        <p class="footer-nav-title">Explore</p>
        <ul class="footer-nav-list">
          {footerLinks.map((item) => (
            <li>
              <a href={item.href}>{item.label}</a>
            </li>
          ))}
        </ul>
      </nav>

      <div class="footer-aside">
        <div>
          <p class="footer-block-title">Follow Us</p>
          <div class="footer-social">
            <a href="#" aria-label="Facebook">
              <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path
                  d="M13.5 22v-8.3h2.8l.4-3.3h-3.2V8.5c0-.9.26-1.5 1.6-1.5H17V4.1c-.3 0-1.4-.1-2.6-.1-2.6 0-4.4 1.6-4.4 4.5v2.5H7v3.3h2.9V22h3.6z"
                />
              </svg>
            </a>
            <a href="#" aria-label="Instagram">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
                <rect x="3" y="3" width="18" height="18" rx="5" />
                <circle cx="12" cy="12" r="4.2" />
                <circle cx="17.5" cy="6.5" r="1.2" fill="currentColor" stroke="none" />
              </svg>
            </a>
            <a href="#" aria-label="YouTube">
              <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path
                  d="M21.6 7.2s-.2-1.4-.8-2c-.8-.8-1.7-.8-2.1-.9C15.7 4 12 4 12 4h0s-3.7 0-6.7.3c-.4 0-1.3.1-2.1.9-.6.6-.8 2-.8 2S2 8.9 2 10.6v1.7c0 1.7.2 3.4.2 3.4s.2 1.4.8 2c.8.8 1.9.8 2.4.9 1.7.2 7.6.3 7.6.3s3.7 0 6.7-.3c.4 0 1.3-.1 2.1-.9.6-.6.8-2 .8-2s.2-1.7.2-3.4v-1.7c0-1.7-.2-3.4-.2-3.4zM9.9 14.5V8.8l5.8 2.9-5.8 2.8z"
                />
              </svg>
            </a>
            <a href="#" aria-label="TikTok">
              <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path
                  d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-5.2 1.74 2.89 2.89 0 012.31-4.64 2.93 2.93 0 01.88.13V9.4a6.84 6.84 0 00-1-.05A6.33 6.33 0 005 20.1a6.34 6.34 0 0010.86-4.43v-7a8.16 8.16 0 004.77 1.52v-3.4a4.85 4.85 0 01-1-.1z"
                />
              </svg>
            </a>
          </div>
          <a class="footer-contact-link" href="#">Contact Us</a>
        </div>

        <div>
          <p class="footer-block-title">Subscribe</p>
          <p class="footer-subscribe-lede">Exclusive training tips, product deals and much more.</p>
          <form class="footer-subscribe-form" action="#" method="get">
            <label class="sr-only" for="footer-email">Email</label>
            <input
              class="footer-email"
              id="footer-email"
              type="email"
              name="email"
              placeholder="Enter your email"
              autocomplete="email"
            />
            <button class="footer-subscribe-btn" type="button">Subscribe</button>
          </form>
          <a class="footer-shop-follow" href="#">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path
                d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"
              />
            </svg>
            Follow on Shop
          </a>
        </div>
      </div>
    </div>

    <div class="site-footer-bottom">
      <p class="footer-legal">
        <span>© 2026, Pupford</span>
        <span class="sep">·</span>
        <span>Powered by Shopify</span>
        {
          legalBits.map((bit) => (
            <span>
              <span class="sep">·</span>
              <a href={bit.href}>{bit.label}</a>
            </span>
          ))
        }
      </p>
    </div>
  </div>
</footer>
