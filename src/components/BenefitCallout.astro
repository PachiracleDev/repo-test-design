---
interface Props {
  label: "High Value" | "Low Calorie" | "Size";
  position: "top-left" | "middle-right" | "bottom-left";
}

const { label, position } = Astro.props;
---

<div class={`benefit-callout benefit-${position}`} data-callout>
  <span class="benefit-icon" aria-hidden="true">
    {
      label === "High Value" && (
        <svg class="benefit-icon-svg" width="18" height="18" viewBox="0 0 24 24" fill="none">
          <path
            d="M12 3l2.5 5.5L20 11l-5.5 2.5L12 19l-2.5-5.5L4 11l5.5-2.5L12 3z"
            stroke="currentColor"
            stroke-width="1.75"
            stroke-linejoin="round"
          />
        </svg>
      )
    }
    {
      label === "Low Calorie" && (
        <svg class="benefit-icon-svg" width="18" height="18" viewBox="0 0 24 24" fill="none">
          <path
            d="M12 3c-4 4-7 8-7 12a7 7 0 1014 0c0-4-3-8-7-12z"
            stroke="currentColor"
            stroke-width="1.75"
            stroke-linejoin="round"
          />
          <path d="M12 9v6" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" />
        </svg>
      )
    }
    {
      label === "Size" && (
        <svg class="benefit-icon-svg" width="18" height="18" viewBox="0 0 24 24" fill="none">
          <path d="M4 20L20 4" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" />
          <path d="M8 4h12v12" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" />
          <path d="M4 8v12h12" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      )
    }
  </span>
  <span class="benefit-label">{label}</span>
</div>
