---
import DiscountBadge from "./DiscountBadge.astro";
import "../styles/hero.css";

/** Hero product: usa CDN si aún no hay `public/pupford-bags.png`. */
const PRODUCT_SRC =
  "https://folio-fotos-proyectos.s3.us-east-2.amazonaws.com/folio/drive-download-20260511T175139Z-3-001/Pupford_photography_product_treat_freezedried-beef-chicken-salmon_whitney_1.jpg";

const headlineLine1 = ["Start", "Fixing", "Bad", "Behavior", "in", "Minutes", "with"];
const headlineAccent = ["Training", "Treats"];
---

<section class="hero" aria-labelledby="hero-title">
  <div class="hero-inner">
    <div class="hero-copy">
      <p class="microproof" data-animate="microproof">
        <span class="stars" aria-hidden="true">★★★★★</span>
        <span>4.6 Stars | 17k+ Reviews</span>
      </p>

      <h1 class="headline" id="hero-title">
        <span class="headline-line">
          {headlineLine1.map((word) => (
            <span class="headline-word" data-word>
              {word}
            </span>
          ))}
        </span>
        <span class="headline-line headline-accent">
          {headlineAccent.map((word) => (
            <span class="headline-word" data-word>
              {word}
            </span>
          ))}
        </span>
      </h1>

      <p class="subtext" data-animate="subtext">
        Pupford Freeze-Dried Training Treats use ultra-light, high-value freeze-dried protein so you can reward often
        without overfeeding.
      </p>

      <a class="cta" href="#" data-animate="cta">
        <span>Improve Bad Behavior Fast</span>
        <span class="cta-arrow" aria-hidden="true">→</span>
      </a>

      <a class="guarantee" href="#" data-animate="guarantee">✓ Backed by the Pupford Promise</a>
    </div>

    <div class="hero-visual">
      <img
        class="hero-product"
        src={PRODUCT_SRC}
        alt="Pupford freeze-dried training treats product bags"
        width="1200"
        height="1500"
        loading="eager"
        decoding="async"
        fetchpriority="high"
        data-animate="product"
      />
    </div>
  </div>

  <DiscountBadge />
</section>
