---
import BenefitCallout from "./BenefitCallout.astro";
import DiscountBadge from "./DiscountBadge.astro";
import "../styles/hero.css";

const ASSETS = {
  productTrio:
    "https://folio-fotos-proyectos.s3.us-east-2.amazonaws.com/folio/drive-download-20260511T175139Z-3-001/Pupford_photography_product_treat_freezedried-beef-chicken-salmon_whitney_1.jpg"
};

const headlineWords = ["Easier", "Training", "Starts", "with"];
const accentWords = ["Better", "Training", "Treats"];
---

<section class="hero" aria-labelledby="hero-title">
  <div class="hero-inner">
    <div class="hero-copy">
      <p class="microproof" data-animate="microproof">
        <span class="stars" aria-hidden="true">★★★★★</span>
        <span>4.6 Stars</span>
        <span class="divider" aria-hidden="true">|</span>
        <span>17k+ Reviews</span>
      </p>

      <h1 class="headline" id="hero-title" aria-label="Easier Training Starts with Better Training Treats">
        <span class="headline-line">
          {headlineWords.map((word) => <span class="headline-word" data-word>{word}</span>)}
        </span>
        <span class="headline-line headline-accent">
          {accentWords.map((word) => <span class="headline-word" data-word>{word}</span>)}
        </span>
      </h1>

      <p class="subtext" data-animate="subtext">
        Pupford Freeze-Dried Training Treats use ultra-light, high-value freeze-dried protein so you can reward often
        without overfeeding.
      </p>

      <a class="cta" href="#" data-animate="cta">
        <span>Improve Bad Behavior Fast</span>
        <span class="cta-arrow" aria-hidden="true">→</span>
      </a>

      <a class="guarantee" href="#" data-animate="guarantee">✓ Backed by the Pupford Promise</a>
    </div>

    <div class="hero-visual">
      <img
        class="hero-product"
        src={ASSETS.productTrio}
        alt="Pupford freeze-dried training treats bags in beef, chicken, and salmon flavors"
        width="2400"
        height="1800"
        loading="eager"
        decoding="async"
        fetchpriority="high"
        data-animate="product"
      />

      <DiscountBadge />

      <div class="hero-callouts">
        <BenefitCallout label="High Value" position="top-left" />
        <BenefitCallout label="Low Calorie" position="middle-right" />
        <BenefitCallout label="Size" position="bottom-left" />
      </div>

      <svg class="connectors" viewBox="0 0 920 700" preserveAspectRatio="none" aria-hidden="true">
        <path class="connector-path connector-top-left" data-connector d="M170,150 C300,120 360,180 435,250" />
        <path class="connector-path connector-middle-right" data-connector d="M756,312 C680,290 620,310 546,342" />
        <path class="connector-path connector-bottom-left" data-connector d="M180,510 C310,518 350,460 423,418" />
      </svg>
    </div>
  </div>
</section>
