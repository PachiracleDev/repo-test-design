---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Hero from "../components/Hero.astro";
import FeaturedLogos from "../components/FeaturedLogos.astro";
import FeatureSection from "../components/FeatureSection.astro";
import ProductsSection from "../components/ProductsSection.astro";
import ReviewsSection from "../components/ReviewsSection.astro";
import Footer from "../components/Footer.astro";
import FabAccount from "../components/FabAccount.astro";
---

<BaseLayout
  title="Pupford Training Treats — Landing demo"
  description="Pupford Freeze-Dried Training Treats."
>
  <Header />
  <main>
    <Hero />
    <FeaturedLogos />
    <FeatureSection />
    <ProductsSection />
    <ReviewsSection />
  </main>
  <Footer />
  <FabAccount />
  <script type="module" src="/hero-scroll-video.js"></script>
</BaseLayout>
